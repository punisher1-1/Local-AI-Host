# Copy to .env and fill in the real IPs/secrets. .env is gitignored + dockerignored.
# These are read by the FastAPI backend (serve.py / makerspace_rag.py) at startup.

# ── Database: external pgvector Postgres (NOT in this container) ──────────────
# psycopg wants a plain postgresql:// URL (no +psycopg driver tag).
DATABASE_URL=postgresql://makerspace:CHANGEME@10.10.10.20:5432/makerspacehub
RAG_TABLE=data_makerspace_rag
TOP_K=4

# ── Generation: vLLM (OpenAI-compatible) on the G9 / RTX 2000 Ada ────────────
# GEN_BASE_URL must include the /v1 suffix. CHAT_MODEL must match /v1/models exactly.
GEN_BINDING=openai
GEN_BASE_URL=http://10.10.10.30:8000/v1
GEN_API_KEY=none
CHAT_MODEL=ibm-granite/granite-4.1-8b-fp8

# ── Embedding: Ollama on the G1a / Strix Halo ────────────────────────────────
# EMBED_MODEL MUST match the model the pgvector index was built with, or
# retrieval returns nonsense (different model = different vector space).
OLLAMA_URL=http://10.10.10.31:11434
EMBED_MODEL=bge-m3:latest
